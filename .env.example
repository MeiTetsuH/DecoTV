# DecoTV Environment Variables Example (Vercel 部署)
# 在 Vercel Dashboard → Settings → Environment Variables 中配置这些变量

# ===== 必需配置 =====

# 存储类型: 'upstash' (推荐) | 'localstorage' (无数据库模式)
NEXT_PUBLIC_STORAGE_TYPE=upstash

# 管理员账号
USERNAME=admin
PASSWORD=your_password_here

# 站点名称
NEXT_PUBLIC_SITE_NAME=DecoTV

# ===== Upstash Redis (使用 upstash 存储时必填) =====
# Vercel Upstash 集成会自动注入以下变量，无需手动配置：
KV_REST_API_URL=
KV_REST_API_TOKEN=
# 也支持以下命名（优先级递减）：
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
# UPSTASH_URL / UPSTASH_TOKEN

# ===== 可选配置 =====

# 用户注册 (需要 upstash 存储)
NEXT_PUBLIC_ENABLE_REGISTRATION=false

# 豆瓣代理
NEXT_PUBLIC_DOUBAN_PROXY_TYPE=cmliussss-cdn-tencent
NEXT_PUBLIC_DOUBAN_PROXY=
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY_TYPE=cmliussss-cdn-tencent
NEXT_PUBLIC_DOUBAN_IMAGE_PROXY=

# TMDB 配置
TMDB_API_KEY=
# TMDB 正向代理地址，例如 http://127.0.0.1:7890
TMDB_PROXY=
# TMDB 反向代理地址，优先级高于 TMDB_PROXY，例如 https://tmdb.example.com
TMDB_REVERSE_PROXY=

# 私人影库配置（也可在 /admin 后台中配置）
# OpenList 服务地址
OPENLIST_URL=
OPENLIST_TOKEN=
OPENLIST_ROOT_PATH=/Media
# Emby
EMBY_URL=
EMBY_API_KEY=
EMBY_USER_ID=
# Jellyfin
JELLYFIN_URL=
JELLYFIN_API_KEY=
JELLYFIN_USER_ID=

# 网盘搜索代理超时 (ms)
PANSOU_PROXY_TIMEOUT_MS=15000

# 成人内容过滤 (默认启用，设为 true 关闭过滤)
NEXT_PUBLIC_DISABLE_YELLOW_FILTER=false

# 流式搜索 (默认启用)
NEXT_PUBLIC_FLUID_SEARCH=true
